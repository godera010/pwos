# P-WOS .gitignore

# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/
.env.local

# ==============================================================================
# Node.js
# ==============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache
.node_repl_history

# ==============================================================================
# IDE / Editors
# ==============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# ==============================================================================
# OS Generated
# ==============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ==============================================================================
# Logs
# ==============================================================================
logs/
*.log
npm-debug.log*

# ==============================================================================
# Environment
# ==============================================================================
.env
.env.local
.env.*.local

# ESP32 firmware credentials (config.h contains WiFi/MQTT secrets)
src/firmware/pwos_esp32/config.h

# ==============================================================================
# Build outputs
# ==============================================================================
src/frontend/dist/
*.min.js
*.min.css

# ==============================================================================
# Testing
# ==============================================================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ==============================================================================
# Temporary files
# ==============================================================================
*.tmp
*.temp
*.bak
*.backup

# ==============================================================================
# Keep these (explicitly tracked)
# ==============================================================================
!.env.example
!data/pwos_simulation.db
!data/training_data.csv
!data/exports/*.sql
!models/*.pkl
!models/*.json

# ==============================================================================
# folders
# ==============================================================================
docs/hardware/New folder