# P-WOS Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# MQTT CONFIGURATION
# ============================================================================
# Options: "local" (Mosquitto) or "cloud" (HiveMQ)
MQTT_MODE=local

# Cloud MQTT (HiveMQ) - only needed if MQTT_MODE=cloud
MQTT_CLOUD_BROKER=your-cluster.s1.eu.hivemq.cloud
MQTT_CLOUD_PORT=8883
MQTT_CLOUD_USER=your-username
MQTT_CLOUD_PASS=your-password

# ============================================================================
# WEATHER API CONFIGURATION
# ============================================================================
# Options: "simulation" or "openweathermap"
WEATHER_API_MODE=simulation

# OpenWeatherMap - only needed if WEATHER_API_MODE=openweathermap
OPENWEATHERMAP_API_KEY=your-api-key-here

# Your location coordinates (for weather forecast)
WEATHER_LATITUDE=-26.2041
WEATHER_LONGITUDE=28.0473

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Options: "sqlite" or "postgresql"
DATABASE_MODE=sqlite

# SQLite path (development)
SQLITE_PATH=pwos_simulation.db

# PostgreSQL URL (production - Railway provides this automatically)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ============================================================================
# FLASK CONFIGURATION
# ============================================================================
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true

# ============================================================================
# HARDWARE / DATA SOURCE CONFIGURATION
# ============================================================================
# Options: "simulation" (default), "hardware", or "hybrid"
DATA_SOURCE_MODE=simulation

# Serial port for USB-connected ESP32 ("auto" = auto-detect)
HARDWARE_SERIAL_PORT=auto

# Device ID expected from real ESP32
HARDWARE_DEVICE_ID=ESP32_PWOS_001

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
FRONTEND_DIST_PATH=../frontend/dist
CORS_ORIGINS=http://localhost:5173,http://localhost:5000
